generator client {
  provider   = "prisma-client"
  output     = "./generated"
  engineType = "client"
  runtime    = "bun"
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String        @id @default(cuid()) @db.VarChar(30)
  email     String        @unique
  name      String
  password  String?
  avatarUrl String?       @db.Text
  isAdmin   Boolean       @default(false)
  credits   Int           @default(7)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deleteAt  DateTime?
  accounts  Account[]
  history   History[]
  payment   Payment[]
  person    User_Person[]
}

model Payment {
  id         String   @id @default(cuid()) @db.VarChar(30)
  externalId String   @unique
  status     String
  productId  String
  userId     String
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id])
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId], map: "Payment_productId_fkey")
  @@index([userId], map: "Payment_userId_fkey")
}

model Product {
  id       String    @id @default(cuid()) @db.VarChar(30)
  name     String
  credits  Int
  price    Float
  currency String
  region   String
  active   Boolean   @default(true)
  payments Payment[]
}

model Account {
  id                String  @id @default(cuid()) @db.VarChar(30)
  provider          String
  providerAccountId String
  accessToken       String? @db.Text
  refreshToken      String? @db.Text
  expiresAt         Int?
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Email_Verification {
  id        String   @id @default(cuid()) @db.VarChar(30)
  email     String   @unique
  name      String
  password  String
  code      String   @db.Char(6)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model User_Person {
  id       Int     @id @default(autoincrement())
  isActive Boolean @default(true)
  userId   String
  personId Int
  person   Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, personId])
  @@index([personId])
}

model Person {
  id          Int           @id @default(autoincrement())
  /// [PersonTraits]
  trait       Json
  icon        String
  /// [PersonDesc]
  desc        Json
  user_person User_Person[]
}

model History {
  id            Int         @id @default(autoincrement())
  createdAt     DateTime    @default(now())
  userId        String
  recommendedId String
  recommended   Recommended @relation(fields: [recommendedId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([recommendedId])
}

model Recommended {
  id              String           @id @default(cuid()) @db.VarChar(30)
  title           String
  img             String           @db.Text
  plot            String           @db.MediumText
  year            String
  creator         String
  rating          String?
  updatedAt       DateTime         @updatedAt
  link            String?          @db.MediumText
  categoryId      Int
  histories       History[]
  recomGenres     Recom_Genre[]
  category        Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  translatedPlots TranslatedPlot[]

  @@unique([title, creator, categoryId])
  @@index([categoryId, title])
}

model TranslatedPlot {
  id            Int         @id @default(autoincrement())
  language      String
  content       String      @db.MediumText
  recommendedId String
  recommended   Recommended @relation(fields: [recommendedId], references: [id], onDelete: Cascade)

  @@unique([recommendedId, language])
}

model Recom_Genre {
  id            Int         @id @default(autoincrement())
  genreId       Int
  recommendedId String
  genre         Genre       @relation(fields: [genreId], references: [id], onDelete: Cascade)
  recommended   Recommended @relation(fields: [recommendedId], references: [id], onDelete: Cascade)

  @@unique([recommendedId, genreId])
  @@index([genreId])
}

model Genre {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  genreTranslations GenreTranslation[]
  recomGenres       Recom_Genre[]
}

model GenreTranslation {
  id       Int    @id @default(autoincrement())
  language String
  content  String
  genreId  Int
  genre    Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@unique([genreId, language])
}

model Category {
  id           Int           @id @default(autoincrement())
  /// [CategoryTitle]
  title        Json
  isActive     Boolean       @default(true)
  recommendeds Recommended[]
}
